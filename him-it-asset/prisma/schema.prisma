// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  Software
  Hardware
  Network
  Access
  Others
}

enum Priority {
  Low
  Medium
  High
  Urgent
}

enum Status {
  Open
  InProgress
  Resolved
  Closed
}

model Ticket {
  id            String   @id @default(uuid())
  ticketNumber  String   @unique
  requesterName  String
  requesterEmail String?
  requesterPhone String?
  department     String
  category      Category
  priority      Priority
  subject       String
  description   String   @db.Text
  status        Status   @default(Open)
  assetId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("tickets")
}

enum AssetCategory {
  Laptop
  Desktop
  Monitor
  Network
  Accessory
  Other
}

enum AssetStatus {
  Available
  Assigned
  InRepair
  Retired
}

enum AssetIssueStatus {
  Pending
  Resolved
}

model Asset {
  id              String        @id @default(uuid())
  assetTag        String        @unique
  name            String
  brand           String?
  model           String?
  specs           String?       @db.Text
  notes           String?       @db.Text
  serialNumber    String?       @unique
  condition       String?
  warranty        String?
  warrantyEnd     DateTime?
  category        AssetCategory
  status          AssetStatus   @default(Available)
  department      String
  assignedUser    String?
  purchaseDate    DateTime?
  invoiceNumber   String?
  qrCodeUrl       String?       @db.Text
  issueCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  issues AssetIssue[]
  logs   AssetLog[]

  @@map("assets")
}

model AssetIssue {
  id               String           @id @default(uuid())
  assetId          String
  ticketId         String?
  ticketNumber     String?
  reportedBy       String
  issueDescription String           @db.Text
  status           AssetIssueStatus @default(Pending)
  dateReported     DateTime         @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("asset_issues")
}

model AssetLog {
  id        String   @id @default(uuid())
  assetId   String
  action    String
  details   String?  @db.Text
  user      String?
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("asset_logs")
}
